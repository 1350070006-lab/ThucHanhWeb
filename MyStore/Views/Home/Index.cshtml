<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trang Web Bán Hàng</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .hidden { display: none; }
        .product-card { cursor: pointer; transition: 0.3s; }
        .product-card:hover { transform: scale(1.02); }
    </style>
</head>
<body>

    <header class="bg-success text-white text-center py-4">
        <h1>Trang Web Bán Hàng</h1>
    </header>

    <nav class="navbar navbar-expand-lg navbar-dark bg-warning mb-4">
        <div class="container">
            <a class="navbar-brand text-dark fw-bold" href="#" onclick="showList()">Trang Chủ</a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link text-dark" href="#">Sản Phẩm</a></li>
                    <li class="nav-item"><a class="nav-link text-dark" href="#">Liên Hệ</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div id="product-list" class="container">
        <div class="row">
            <div class="col-md-9">
                <div class="row row-cols-1 row-cols-md-3 g-4">
                    <div class="col">
                        <div class="card h-100 product-card" onclick="showDetail('Sản Phẩm 1', '$100', 'https://picsum.photos/id/684/800/600', 'Mô tả chi tiết cho sản phẩm 1 cực kỳ chất lượng.')">
                            <img src="https://picsum.photos/id/684/600/400" class="card-img-top" alt="SP1">
                            <div class="card-body text-center">
                                <h5 class="card-title text-primary">Sản Phẩm 1</h5>
                                <p class="card-text">Mô tả sản phẩm 1.</p>
                                <p class="card-text fw-bold">Giá: $100</p>
                                <button class="btn btn-primary">Mua Ngay</button>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card h-100 product-card" onclick="showDetail('Sản Phẩm 2', '$150', 'https://picsum.photos/id/659/800/600', 'Mô tả chi tiết cho sản phẩm 2 với nhiều tính năng mới.')">
                            <img src="https://picsum.photos/id/659/600/400" class="card-img-top" alt="SP2">
                            <div class="card-body text-center">
                                <h5 class="card-title text-primary">Sản Phẩm 2</h5>
                                <p class="card-text">Mô tả sản phẩm 2.</p>
                                <p class="card-text fw-bold">Giá: $150</p>
                                <button class="btn btn-primary">Mua Ngay</button>
                            </div>
                        </div>
                    </div>
                    </div>
            </div>

            <div class="col-md-3">
                <div class="bg-primary text-white p-3 rounded">
                    <h5>Social Media</h5>
                    <ul class="list-unstyled mb-0">
                        <li>Facebook</li>
                        <li>Twitter</li>
                        <li>Instagram</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div id="product-detail" class="container hidden">
        <div class="row">
            <div class="col-md-6">
                <img id="detail-img" src="" class="img-fluid rounded shadow" alt="Large Image">
            </div>
            <div class="col-md-6">
                <h1 id="detail-title" class="display-5 fw-bold"></h1>
                <h3 id="detail-price" class="text-danger fw-bold"></h3>
                <hr>
                <h5>Mô tả chi tiết:</h5>
                <p id="detail-desc" class="lead"></p>
                <div class="mt-4">
                    <button class="btn btn-success btn-lg">Thêm vào giỏ hàng</button>
                    <button class="btn btn-outline-secondary btn-lg" onclick="showList()">Quay lại danh sách</button>
                </div>
            </div>
        </div>
    </div>

    <footer class="container mt-5">
        <div class="row">
            <div class="col-md-4"><div class="bg-dark text-white text-center py-4"><h3>Cột 1</h3><p>Nội dung cột 1.</p></div></div>
            <div class="col-md-4"><div class="bg-dark text-white text-center py-4"><h3>Cột 2</h3><p>Nội dung cột 2.</p></div></div>
            <div class="col-md-4"><div class="bg-dark text-white text-center py-4"><h3>Cột 3</h3><p>Nội dung cột 3.</p></div></div>
        </div>
    </footer>

    <script>
        function showDetail(title, price, img, desc) {
            document.getElementById('product-list').classList.add('hidden');
            document.getElementById('product-detail').classList.remove('hidden');
            
            document.getElementById('detail-title').innerText = title;
            document.getElementById('detail-price').innerText = "Giá: " + price;
            document.getElementById('detail-img').src = img;
            document.getElementById('detail-desc').innerText = desc;
            window.scrollTo(0,0);
        }

        function showList() {
            document.getElementById('product-list').classList.remove('hidden');
            document.getElementById('product-detail').classList.add('hidden');
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>